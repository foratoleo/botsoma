# Microsoft Entra ID (App Registration)
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TENANT_ID=

# LLM (z.ai / Anthropic-compatible)
ZAI_API_KEY=
ZAI_MODEL=GLM-5-Turbo
ZAI_BASE_URL=https://api.z.ai/api/anthropic/v1/messages
ZAI_TIMEOUT_MS=15000

# Bot Settings
BOT_PORT=3978
BOT_NAME=Suporte IA

# Knowledge Base
# Path to directory containing .md/.txt files (relative to project root)
KNOWLEDGE_BASE_DIR=docs/knowledge

# Escalation - comma-separated Teams user IDs that receive error escalations
SUPPORT_USER_IDS=

# Optional: Teams channel ID for escalation posts
SUPPORT_CHANNEL_ID=
