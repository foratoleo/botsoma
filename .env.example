# Microsoft Entra ID (App Registration)
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TENANT_ID=

# LLM (z.ai / Anthropic-compatible)
ZAI_API_KEY=
ZAI_MODEL=GLM-5-Turbo
ZAI_BASE_URL=https://api.z.ai/api/anthropic/v1/messages
ZAI_TIMEOUT_MS=15000

# Bot Settings
BOT_PORT=3978
BOT_NAME=Suporte IA

# Knowledge Base
KNOWLEDGE_BASE_DIR=docs/knowledge

# Embedding Model (for semantic search)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
FAISS_INDEX_PATH=.cache/faiss_index
EMBEDDING_TOP_K=5

# Hybrid Search (BM25 + semantic)
HYBRID_SEARCH_ENABLED=true
HYBRID_RRF_K=60
HYBRID_SPARSE_TOP_K=20

# Redis Session Store (leave empty for in-memory fallback)
REDIS_URL=

# Escalation - comma-separated Teams user IDs that receive error escalations
SUPPORT_USER_IDS=

# Optional: Teams channel ID for escalation posts
SUPPORT_CHANNEL_ID=
